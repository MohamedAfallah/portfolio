<style>
    :root {
        --primary: #4f39fa;
        --secondary: #da62c4;
        --bg: #0a0c10;
        --card-bg: #111418;
        --text: #ffffff;
        --text-muted: #a0a0a0;
        --font-main: 'Inter', system-ui, sans-serif;
    }

    * { box-sizing: border-box; }

    body {
        font-family: var(--font-main);
        background: var(--bg);
        color: var(--text);
        max-width: 900px;
        margin: auto;
        padding: 4rem 1.5rem;
        line-height: 1.6;
        overflow-x: hidden;
    }

    header { margin-bottom: 4rem; text-align: center; }
    h1 { font-size: clamp(2.5rem, 8vw, 4rem); margin: 0; letter-spacing: -2px; font-weight: 800; line-height: 1.1; }
    
    .text-gradient {
        background: linear-gradient(45deg, var(--primary), var(--secondary));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    
    .role { font-size: clamp(1.2rem, 4vw, 1.8rem); color: var(--text-muted); margin: 1rem 0; font-weight: 500; }
    .location { color: var(--primary); font-weight: 600; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.5rem; display: block;}

    h2 { font-size: 1.8rem; border-bottom: 2px solid #222; padding-bottom: 0.5rem; margin-bottom: 2rem; margin-top: 4rem; }

    .skills-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
    }
    .skill-category {
        background: var(--card-bg);
        padding: 1.5rem;
        border-radius: 12px;
        border: 1px solid #1c2126;
    }
    .category-title { color: var(--secondary); font-weight: 700; display: block; margin-bottom: 0.5rem; font-size: 1rem; text-transform: uppercase; }
    .skill-category p { font-size: 0.9rem; color: #ccc; margin: 0.5rem 0; }

    .proyecto-card {
        background: var(--card-bg);
        padding: clamp(1.5rem, 5vw, 3rem);
        border-radius: 16px;
        border: 1px solid #1c2126;
        margin-bottom: 3rem;
    }
    .header-proyecto { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; }
    .header-proyecto h3 { font-size: 1.3rem; margin: 0; }
    .tag { background: rgba(79, 57, 250, 0.1); color: var(--primary); padding: 4px 10px; border-radius: 15px; font-size: 0.75rem; font-weight: 600; border: 1px solid rgba(79, 57, 250, 0.2);}
    
    .tech-stack { display: flex; gap: 8px; flex-wrap: wrap; margin: 1.5rem 0; }
    .tech-stack span { background: #1c2126; color: var(--secondary); padding: 4px 10px; border-radius: 6px; font-size: 0.8rem; font-family: monospace; }
    
    .detalles-tecnicos { border-left: 3px solid var(--primary); padding-left: 1.5rem; list-style: none; margin: 1.5rem 0; }
    .detalles-tecnicos li { margin-bottom: 10px; color: #ddd; font-size: 0.95rem; }

    .btn-github {
        background: linear-gradient(45deg, var(--primary), #6c5ce7);
        color: white;
        text-decoration: none;
        padding: 12px 24px;
        border-radius: 8px;
        font-weight: 700;
        display: inline-block;
        font-size: 0.9rem;
    }

    .privacidad-badge {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.8rem;
        color: var(--text-muted);
        background: rgba(255, 255, 255, 0.05);
        padding: 8px;
        border-radius: 6px;
    }

    .educacion-item { margin-bottom: 1.5rem; background: rgba(255,255,255,0.03); padding: 1.2rem; border-radius: 8px;}

    footer { text-align: center; margin-top: 6rem; padding: 4rem 1.5rem; border-top: 1px solid #222; }
    .social-links { display: flex; justify-content: center; gap: 20px; margin: 2rem 0; }
    .social-icon { color: var(--text-muted); width: 50px; height: 50px; background: #111; border-radius: 50%; display: flex; align-items: center; justify-content: center; border: 1px solid #222; transition: 0.3s; text-decoration: none; }
    .social-icon:hover { transform: translateY(-3px); border-color: var(--primary); color: white; box-shadow: 0 5px 15px rgba(79, 57, 250, 0.3); }
    
    .social-icon.github:hover { border-color: white; color: white; }
    .social-icon.linkedin:hover { border-color: #0077b5; color: #0077b5; }
    .social-icon.gmail:hover { border-color: #ea4335; color: #ea4335; }

    @media (max-width: 480px) {
        body { padding: 2rem 1rem; }
        .detalles-tecnicos { padding-left: 1rem; }
        .header-proyecto h3 { font-size: 1.1rem; }
    }
</style>